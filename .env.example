# Base URL for the API. Required when calling rangeService from a Server Component
# or any Node.js context where relative URLs are not valid.
#
# Leave empty (or omit this file entirely) for local development and Client Components —
# the service will fall back to the relative path '/api/range' resolved by the browser.
#
# Example for a custom domain deployment:
# NEXT_PUBLIC_API_URL=https://your-domain.vercel.app
#
# Example for local SSR testing:
# NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=
